# Copy this file to .env.local and fill in values for your setup.
# .env.local is gitignored, never commit it.

# URL the BROWSER uses to reach the backend (must be reachable from the user's machine).
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1/

# URL the Next.js SERVER (Node/SSR) uses to reach the backend.
# Leave unset if your Node process and the backend share the same host (most setups).
# Set to http://host.docker.internal:8000/api/v1/ when running the frontend inside a devcontainer.
# In production set this to the same value as NEXT_PUBLIC_API_URL (your real API domain).
# API_URL=http://host.docker.internal:8000/api/v1/

NODE_ENV=development
